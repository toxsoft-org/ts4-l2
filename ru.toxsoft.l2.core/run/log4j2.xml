<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <!-- Настройка логгеров -->
    <Loggers>
        <!-- Настройка журналов компонент системы -->
        <Logger level="WARN"   name="org.xnio" />
        <Logger level="WARN"   name="org.jboss" />
        <Logger level="WARN"   name="org.jboss" />
        <Logger level="WARN"   name="org.jboss.ejb.client" />
        <Logger level="WARN"   name="org.wildfly" />

        <Logger level="INFO"  name="org.toxsoft" />
        
        <Logger level="WARN"  name="org.toxsoft.core.tslib.bricks.threadexec.TsThreadExecutor" />
        <logger level="INFO"  name="org.toxsoft.core.pas.common.PasChannel" />

        <Logger level="INFO"  name="org.toxsoft.uskat.core" />
        <Logger level="WARN"  name="org.toxsoft.uskat.core.impl.SkCoreServObject" />
        
        

        <Logger level="INFO"  name="org.toxsoft.uskat.s5.common" />
        <Logger level="WARN"  name="org.toxsoft.uskat.s5.common.sysdescr.SkSysdescrReader" />
        <Logger level="INFO"  name="org.toxsoft.uskat.s5.client" />
        <Logger level="INFO"  name="org.toxsoft.uskat.s5.client.remote.S5BackendRemote" />        
        <Logger level="INFO"  name="org.toxsoft.uskat.s5.server" />



        <Logger level="ALL"   name="ru.toxsoft" />
        
        <!-- Корневой логгер: уровень ERROR, выводит в оба аппендера -->
        <Root level="ALL">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>

    <!-- Определение аппендеров -->
    <Appenders>
        <!-- Консольный аппендер -->
        <Console name="Console" target="SYSTEM_OUT">
            <ThresholdFilter level="ALL" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="[%-5level|%d{HH:mm:ss.SSS}|%-20c{1}] %msg%n%ex{full}"/>
        </Console>

        <!-- Файловый аппендер с ротацией по дням недели -->
        <RollingFile name="File"
                     fileName="logs/app.log"
                     filePattern="logs/app-%d{EEEE}.log">
            <ThresholdFilter level="ALL" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="[%-5level|%d{yyyy-MM-dd HH:mm:ss.SSS}|%-20logger{36}|%-25t{36}] %msg%n%ex{full}"/>
            <Policies>
                <!-- Политика ротации по времени: каждый день -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
            </Policies>
            <!-- Стратегия переименования: при ротации файл app.log переименовывается в app-{день недели}.log -->
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>
    </Appenders>

</Configuration>